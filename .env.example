# =============================================================================
# M365 LangChain Agent — Environment Configuration
# =============================================================================
# LangChain RAG agent with Bot Framework + CosmosDB, deployed on Azure Container Apps.
# Queries a search index on Azure AI Search (hybrid: keyword + vector + semantic).
#
# Auth: Uses Azure Managed Identity (DefaultAzureCredential) — no API keys needed.
#
# IMPORTANT: Copy to .env and fill in values. Do NOT commit .env to git.
# =============================================================================


# -----------------------------------------------------------------------------
# Azure Identity — required when multiple user-assigned identities exist
# -----------------------------------------------------------------------------
AZURE_CLIENT_ID=<your-managed-identity-client-id>              # User-assigned MSI client ID for DefaultAzureCredential

# -----------------------------------------------------------------------------
# Azure OpenAI — LLM + Embeddings (auth via Managed Identity)
# -----------------------------------------------------------------------------
AZURE_OPENAI_ENDPOINT=<your-azure-openai-endpoint>              # e.g. https://<resource>.cognitiveservices.azure.com
AZURE_OPENAI_DEPLOYMENT_NAME=<your-llm-deployment-name>         # e.g. gpt-4.1
AZURE_OPENAI_API_VERSION=2024-05-01-preview
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=<your-embedding-deployment>   # e.g. text-embedding-3-large
AZURE_OPENAI_AVAILABLE_MODELS=gpt-4.1,gpt-4.1-mini,o3-mini    # Comma-separated deployment names for model selector

# -----------------------------------------------------------------------------
# Azure AI Search — populated by the ingestion pipeline (auth via Managed Identity)
# -----------------------------------------------------------------------------
AZURE_SEARCH_ENDPOINT=<your-search-endpoint>                    # e.g. https://<service>.search.windows.net
AZURE_SEARCH_INDEX_NAME=<your-search-index-name>                # e.g. nfcu-rag-index
AZURE_SEARCH_SEMANTIC_CONFIG_NAME=<your-semantic-config-name>   # e.g. custom-kb-semantic-config
AZURE_SEARCH_EMBEDDING_FIELD=content_vector

# -----------------------------------------------------------------------------
# Azure CosmosDB — Conversation state (auth via Managed Identity)
# -----------------------------------------------------------------------------
AZURE_COSMOS_ENDPOINT=<your-cosmos-endpoint>                    # e.g. https://<account>.documents.azure.com:443/
AZURE_COSMOS_DATABASE=m365-langchain-agent
AZURE_COSMOS_CONTAINER=conversations

# -----------------------------------------------------------------------------
# Bot Framework — Bot Service identity
# -----------------------------------------------------------------------------
BOT_APP_ID=<your-bot-app-id>                                   # Bot Service MSI client ID or App Registration ID
BOT_APP_PASSWORD=                                               # Leave empty for MSI auth

# -----------------------------------------------------------------------------
# Chainlit — required for conversation history sidebar
# -----------------------------------------------------------------------------
CHAINLIT_AUTH_SECRET=<your-jwt-secret>                          # Generate: python3 -c "import secrets; print(secrets.token_hex(32))"

# -----------------------------------------------------------------------------
# Entra ID SSO (Single Sign-On) — For Chainlit UI authentication
# -----------------------------------------------------------------------------
ENABLE_SSO=true                                                  # true = enforce SSO authentication, false = no auth (dev only)
ENTRA_TENANT_ID=<your-tenant-id>                                 # Azure AD / Entra ID tenant ID
ENTRA_CLIENT_ID=<your-app-registration-client-id>                # App Registration client ID
ENTRA_CLIENT_SECRET=<your-app-registration-secret>               # App Registration client secret (store in Container Apps secrets)
ENTRA_REDIRECT_URI=<your-redirect-uri>                           # OAuth callback URL (e.g. https://<fqdn>/chat/auth/callback)
SESSION_SECRET=<your-session-secret>                             # Secret key for encrypting session cookies (32+ bytes, random)
SESSION_MAX_AGE=28800                                            # Absolute max session lifetime in seconds (default: 8 hours = 28800)
SESSION_IDLE_TIMEOUT=900                                         # Idle timeout in seconds — session expires after this much inactivity (default: 15 min = 900)

# Group-based RBAC (optional) — Restrict access and admin features
AI_VA_USERS_GROUP_ID=<your-users-group-oid>                      # Entra ID group OID for app access
AI_VA_ADMINS_GROUP_ID=<your-admins-group-oid>                    # Entra ID group OID for admin features

# -----------------------------------------------------------------------------
# Azure AI Foundry — Agent registration (for scripts/register_foundry_agent.py)
# -----------------------------------------------------------------------------
AZURE_FOUNDRY_ENDPOINT=<your-foundry-endpoint>                  # e.g. https://eastus2.api.azureml.ms
AZURE_FOUNDRY_SUBSCRIPTION_ID=<your-subscription-id>
AZURE_FOUNDRY_RESOURCE_GROUP=<your-resource-group>
AZURE_FOUNDRY_WORKSPACE=<your-foundry-workspace>                # e.g. my-agent-project

# -----------------------------------------------------------------------------
# LangSmith Tracing (optional)
# -----------------------------------------------------------------------------
LANGCHAIN_TRACING_V2=true
LANGCHAIN_PROJECT=m365-langchain-agent
LANGSMITH_API_KEY=<your-langsmith-api-key>

# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------
LOG_LEVEL=INFO
PORT=8080
USER_INTERFACE=BOT_SERVICE                                    # BOT_SERVICE or CHAINLIT_UI
SHOW_CHAT_SETTINGS=true                                       # true = show gear icon / settings panel, false = hide it
SHOW_DEBUG_PANELS=false                                       # true = show debug accordions (chunks, prompt, settings), false = hide
SHOW_SUGGESTED_PROMPTS=true                                   # true = show 3 follow-up suggestion chips after each response
SHOW_STARTER_PROMPTS=true                                     # true = show starter prompt chips below composer, false = hide

# Starter prompts — JSON array of {label, message} objects shown in empty chat state
# Set to empty array [] to disable starters
STARTER_PROMPTS=[{"label":"End-to-End Data Lineage","message":"Show me the end-to-end data lineage for ACCT_ID from Landing through RAW, INT, CUR to ASL in the Core Banking STTM"},{"label":"Field Mapping Details","message":"What are the field mappings and transformation logic from RAW to INT for payment transactions?"},{"label":"Search Knowledge Base","message":"What documentation do we have about the loan origination process?"},{"label":"Browse Available Documents","message":"What STTM workbooks and documentation are available in the knowledge base?"}]
DEFAULT_TOP_K=10                                              # Default chunks to retrieve (adjustable in Chainlit UI)
DEFAULT_TEMPERATURE=0.2                                       # Default LLM temperature (adjustable in Chainlit UI)

# -----------------------------------------------------------------------------
# Source URL Reconstruction — builds clickable links from ADLS blob paths
# -----------------------------------------------------------------------------
SHAREPOINT_BASE_URL=                                          # e.g. https://<tenant>.sharepoint.com/sites/<site>/Shared Documents
WIKI_BASE_URL=                                                # e.g. https://dev.azure.com/<org>/<project>/_wiki/wikis/<wiki-name>
